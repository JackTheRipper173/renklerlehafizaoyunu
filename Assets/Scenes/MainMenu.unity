  m_Name: 
  m_EditorClassIdentifier: 
  infoPanel: {fileID: 346434077}
  titleText: {fileID: 2115684818}
  descriptionText: {fileID: 0}
  titleMessage: "Nas\u0131l Oynan\u0131r?"
  descriptionMessage: "Her seviye kendi i\xE7inde farkl\u0131 bir sistem bar\u0131nd\u0131r\u0131r.\nSeviye
    ba\u015Flarken size belirli bir puan verilir. Sizden istenen hedefe uygun \u015Fekilde
    her soruda en mant\u0131kl\u0131 se\xE7ene\u011Fi i\u015Faretleyin.\nYe\u015Fil
    se\xE7enekler en risksiz, maviler n\xF6tr ve k\u0131rm\u0131z\u0131lar en riskli
    olanlar\u0131 ifade eder.\nUnutmay\u0131n, her soru ba\u015F\u0131na belirli
    bir s\xFCreniz var. E\u011Fer i\u015Faretleme yapmazsan\u0131z puan\u0131n\u0131za
    etki etmeden soruyu ge\xE7mi\u015F olursunuz.\nBol \u015Eans!"
  fadeDuration: 0.3
